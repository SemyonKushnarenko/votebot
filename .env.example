BOT_TOKEN=123456:ABCDEF
# For platforms that require an open port (Render/Heroku/etc.).
PORT=3000
# Telegram webhook URL (must be public HTTPS). If empty, bot uses polling.
# Example: https://votebot-git-main-simons-projects-6b6d83bd.vercel.app/telegram/webhook
WEBHOOK_URL=
# Optional: restrict admin-only commands to these user IDs (comma-separated).
# If empty, bot will allow any Telegram group admin to use /new.
SUPERADMINS=

# Optional timezone for parsing DD-MM HH:MM (default: Europe/Moscow)
TZ=Europe/Moscow

